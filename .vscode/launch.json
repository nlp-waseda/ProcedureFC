    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python デバッガー: 現在のファイル",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Factcheck",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/Main.py",
            "console": "integratedTerminal"
        },
        {
            "name": "OpenAIDefaultBench",
            "type": "debugpy",
